{
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "api": ["api/axiosConfig.js"],
      "api/*": ["api/*"],
      "components": ["components"],
      "components/*": ["components/*"],
      "context": ["context/index.js"],
      "context/*": ["context/*"],
      "hooks": ["hooks"],
      "hooks/*": ["hooks/*"],
      "layouts": ["layouts"],
      "layouts/*": ["layouts/*"],
      "middleware": ["middleware/index.js"],
      "middleware/*": ["middleware/*"],
      "pages": ["pages"],
      "pages/*": ["pages/*"],
      "router": ["router/index.js"],
      "router/*": ["router/*"],
      "styles": ["styles"],
      "styles/*": ["styles/*"],
      "utils": ["utils/index.js"],
      "utils/*": ["utils/*"]
    }
  },
  "include": ["src"]
}
