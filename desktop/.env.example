V12_LOCAL_PORT=5100
V12_LOCAL_DB_PATH=./data/v12-pdv.sqlite
V12_ERP_API_URL=https://v12.jhes.com.br/api
V12_ERP_SYNC_TOKEN=troque-este-token
V12_ESTACAO_NOME=Caixa 01
V12_ACBR_MODE=lib
V12_ACBR_MONITOR_HOST=127.0.0.1
V12_ACBR_MONITOR_PORT=3434
V12_ACBRLIB_NFE_PATH=
V12_ACBRLIB_SCHEMA_PATH=
V12_ACBRLIB_NFE_SERVICOS_PATH=
V12_ACBRLIB_CONFIG_DIR=./data/acbrlib/config
V12_ACBRLIB_TEMP_DIR=./data/acbrlib/runtime
V12_ACBRLIB_LOG_DIR=./data/acbrlib/log

# Backup fiscal local
# O PDV compacta e envia para a retaguarda. A retaguarda faz upload para o Drive.
V12_BACKUP_ENABLED=false
V12_BACKUP_AUTO_INTERVAL_MINUTES=0
V12_BACKUP_DIR=./data/backups
V12_BACKUP_7Z_PATH=7z
V12_BACKUP_LOCAL_RETENTION_DAYS=30

# Atualização do PDV
V12_PDV_VERSION=0.1.0
V12_PDV_RELEASE_CHANNEL=stable
V12_PDV_RELEASE_PLATFORM=win32-x64
V12_PDV_RELEASE_DIR=./data/releases
V12_PDV_VERSION_DIR=./data/versions
V12_PDV_RESOURCE_DIR=./data/resources
V12_PDV_RELEASE_AUTO_CHECK_MINUTES=30
