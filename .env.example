TZ=America/Sao_Paulo
NODE_ENV=production

POSTGRES_USER=v12_user
POSTGRES_PASSWORD=troque-esta-senha-forte
POSTGRES_DB=db_v12
POSTGRES_EXPOSE_PORT=5435

API_PORT=4000
API_EXPOSE_PORT=4000
PAYMENTS_PORT=4200
PAYMENTS_EXPOSE_PORT=4200
MESSAGE_PORT=4300
MESSAGE_EXPOSE_PORT=4300
ACBR_PORT=4100
ACBR_EXPOSE_PORT=4100
FRONT_EXPOSE_PORT=3000
EVOLUTION_API_EXPOSE_PORT=8090
NPM_EXTERNAL_NETWORK=nginx-proxy-manager_default

CHAVE_TOKEN=troque-esta-chave-longa-em-producao
AUTH_DEBUG=false
PAYMENTS_SERVICE_TOKEN=troque-este-token-interno-em-producao
MESSAGE_SERVICE_TOKEN=troque-este-token-message-em-producao
EVOLUTION_AUTH_KEY=troque-esta-chave-global-da-evolution
EVOLUTION_SERVER_URL=https://whatsapp.seudominio.com.br
MESSAGE_EVOLUTION_DEFAULT_INSTANCE=v12-main
COOKIE_DOMAIN=v12.jhes.com.br
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax

CORS_ORIGINS=https://v12.jhes.com.br
VITE_API_URL=/api
VITE_ACBR_API_URL=/acbr
ACBRLIB_ENABLED=true
ACBR_DEBUG_CONFIG=false
ACBRLIB_PATH=./lib/ACBrLibNFE/linux/CONSOLE-MT/libacbrnfe64.so
ACBRLIB_CONFIG_DIR=./config/acbrlib
ACBRLIB_TEMP_DIR=./temp
ACBRLIB_SCHEMA_PATH=./lib/ACBrLibNFE/dep/Schemas
# Padrao Linux dos demos ACBrLib: OpenSSL, HTTP OpenSSL, assinatura LibXml2, TLS 1.2.
ACBR_DFE_SSL_CRYPT_LIB=1
ACBR_DFE_SSL_HTTP_LIB=3
ACBR_DFE_SSL_XML_SIGN_LIB=4
ACBR_NFE_SSL_TYPE=5
ACBR_SERVICE_URL=http://acbr:4100
