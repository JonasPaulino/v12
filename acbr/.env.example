# Microservico ACBR
PORT=4100

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123456
DB_DATABASE=database_v12

# Deve ser a mesma chave do backend principal
CHAVE_TOKEN=sua_chave_jwt_compartilhada_com_o_backend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

ACBRLIB_ENABLED=false
ACBR_DEBUG_CONFIG=false
ACBRLIB_PATH=./lib/ACBrLibNFE/linux/CONSOLE-MT/libacbrnfe64.so
ACBRLIB_CONFIG_DIR=./config/acbrlib
ACBRLIB_TEMP_DIR=./temp
ACBRLIB_SCHEMA_PATH=./lib/ACBrLibNFE/dep/Schemas/NFe
# Padrao Linux dos demos ACBrLib: OpenSSL, HTTP OpenSSL, assinatura LibXml2, TLS 1.2.
ACBR_DFE_SSL_CRYPT_LIB=1
ACBR_DFE_SSL_HTTP_LIB=3
ACBR_DFE_SSL_XML_SIGN_LIB=4
ACBR_NFE_SSL_TYPE=5

# MDF-e usa biblioteca e schemas próprios.
ACBRLIB_MDFE_PATH=./lib/ACBrLibMDFe/Linux/CONSOLE-MT/libacbrmdfe64.so
ACBRLIB_MDFE_CONFIG_DIR=./config/acbrlib-mdfe
ACBRLIB_MDFE_TEMP_DIR=./temp-mdfe
ACBRLIB_MDFE_SCHEMA_PATH=./lib/ACBrLibMDFe/dep/Schemas/MDFe
ACBRLIB_MDFE_SERVICOS_PATH=./lib/ACBrLibMDFe/dep/ACBrMDFeServicos.ini
ACBR_MDFE_SSL_TYPE=5
