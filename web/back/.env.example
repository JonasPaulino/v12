# Backend principal do ERP
PORT=4000
NODE_ENV=development
DB_HOST=localhost
DB_PORT=5432
DB_USER=v12
DB_PASSWORD=v12_password
DB_DATABASE=v12_db
CHAVE_TOKEN=troque-esta-chave
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
TOKEN_EXPIRES_IN=8h

# Integracao interna com o microservico de pagamentos
PAYMENTS_SERVICE_URL=http://localhost:4200
PAYMENTS_SERVICE_TOKEN=troque-este-token-interno

# Integracao interna com o microservico de mensagens
MESSAGE_SERVICE_URL=http://localhost:4300
MESSAGE_SERVICE_TOKEN=troque-este-token-message
DESKTOP_SYNC_TOKEN=troque-este-token-desktop
CHAT_WHATSAPP_NOTIFICATION_JOB_ENABLED=true
CHAT_WHATSAPP_NOTIFICATION_JOB_INTERVAL_MS=60000

# Backup fiscal PDV -> Retaguarda -> Google Drive
# Preferencialmente configure pela Gestão V12. Use env apenas como fallback operacional.
PDV_BACKUP_MAX_FILE_SIZE=1073741824
GESTAO_BACKUP_GOOGLE_DRIVE_FOLDER_ID=
GESTAO_BACKUP_GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GESTAO_BACKUP_GOOGLE_SERVICE_ACCOUNT_JSON=
GESTAO_BACKUP_GOOGLE_SCOPE=https://www.googleapis.com/auth/drive.file

# Integracao interna com o microservico fiscal ACBr
ACBR_SERVICE_URL=http://localhost:4100
